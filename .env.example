# Example environment variables for future backend/API work
# Copy this file to .env and fill in real values locally.

# App mode
APP_ENV=development
APP_DEBUG=true

# Backend / PKI settings
API_BASE_URL=http://localhost:8000
PKI_PUBLIC_KEY_PATH=./secrets/public_key.pem
PKI_PRIVATE_KEY_PATH=./secrets/private_key.pem

# Database
DATABASE_URL=sqlite:///./jejak.db

# Logging
LOG_LEVEL=INFO

# Security / demo defaults
JWT_SECRET=change-me
SESSION_SECRET=change-me-too